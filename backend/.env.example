# ════════════════════════════════════════════════════════════════
#  LLM RAG Backend — Environment Variables
#  Copy this file to .env and fill in your actual values
#  NEVER commit .env to git
# ════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-secure-32-char-secret-key

# JWT lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# asyncpg connection string for SQLAlchemy (optional — only if using ORM directly)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-id.supabase.co:5432/postgres

# ── Groq API ─────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Qdrant ───────────────────────────────────────────────────────
# Local dev: localhost (docker compose up)
# Docker (backend in container): qdrant  ← service name in docker-compose
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=exam_documents

# ── Embedding Model ──────────────────────────────────────────────
# BGE-M3 — multilingual, strong Thai support
# First run will download ~2.3 GB to ~/.cache/huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu   # change to "cuda" if GPU available

# ── LLM ──────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
