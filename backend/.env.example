# App
APP_ENV="development"

# JWT
JWT_SECRET_KEY="change-me-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase REST (optional but recommended)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_KEY="<supabase-anon-or-service-key>"
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# Supabase PostgreSQL (required by Prisma)
# Connection pooler URL
DATABASE_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL (used for migrations / db push)
DIRECT_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Groq API
GROQ_API_KEY="gsk_<your-groq-api-key>"

# Qdrant
# Local run with Docker: keep localhost
# Docker backend service in compose overrides this to "qdrant"
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME="exam_documents"

# Embedding (BGE-M3)
EMBEDDING_MODEL="BAAI/bge-m3"
EMBEDDING_DEVICE="cpu"
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# Retrieval tuning
QDRANT_TOP_K=5
QDRANT_SCORE_THRESHOLD=0.3

# LLM tuning
LLM_MODEL="llama-3.3-70b-versatile"
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2
